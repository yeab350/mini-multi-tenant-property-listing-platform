# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mini_property
DB_SYNC=true
DB_LOG=false

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
ALLOW_ROLE_SELF_ASSIGN=true

# Seed demo data on start
SEED_ON_START=true
SEED_PASSWORD=password

# Notes:
# - If you use Docker compose, DB_PASSWORD should match POSTGRES_PASSWORD.
# - If you use an existing local Postgres install, set DB_PASSWORD accordingly.
